# Backend Environment Variables (example)

NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/hris_v2_dev
MONGO_URI_TEST=mongodb://localhost:27017/hris_test

# JWT
JWT_SECRET=replace-with-a-secure-secret
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=replace-with-64-char-hex-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-supabase-service-key

# Email (Brevo)
BREVO_API_KEY=replace-with-brevo-api-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5176

# reCAPTCHA
RECAPTCHA_SECRET=replace-with-recaptcha-secret

# Microsoft Teams / Azure AD
MSAL_CLIENT_ID=replace-with-client-id
MSAL_TENANT_ID=replace-with-tenant-id
MSAL_CLIENT_SECRET=replace-with-client-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

{
  "name": "hris-ats-server",
  "version": "1.0.0",
  "description": "HRIS/ATS Backend - Node.js + Express + MongoDB",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js,json --ignore logs/** --delay 300ms src/server.js",
    "start": "node src/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .js"
  },
  "keywords": ["hris", "ats", "hr", "recruitment"],
  "author": "Madison 88",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "winston": "^3.8.0",
    "@supabase/supabase-js": "^2.31.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "vitest": "^0.34.0",
    "supertest": "^6.3.3",
    "@vitest/coverage-v8": "^0.34.0",
    "eslint": "^8.45.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
